#define _CRT_SECURE_NO_WARNINGS
#include <graphics.h>
#include <conio.h>
#include <vector>
#include <cstdlib>
#include <ctime>
#include <cmath>

const int WIDTH = 480;
const int HEIGHT = 800;

class Player {
public:
    int x, y, radius, speed;
    Player(int _x, int _y) : x(_x), y(_y), radius(20), speed(10) {}

    void Draw() {
        setfillcolor(YELLOW);
        fillcircle(x, y, radius);
        setlinecolor(WHITE);
        circle(x, y, radius);
    }

    void Input() {
        if (GetAsyncKeyState(VK_LEFT) & 0x8000) x -= speed;
        if (GetAsyncKeyState(VK_RIGHT) & 0x8000) x += speed;
        if (x < radius) x = radius;
        if (x > WIDTH - radius) x = WIDTH - radius;
    }
};

class Enemy {
public:
    int x, y;
    int speed;
    int radius;
    COLORREF color;

    Enemy(int _x, int _y, int _speed, int _r, COLORREF _c)
        : x(_x), y(_y), speed(_speed), radius(_r), color(_c) {
    }

    void Update() {
        y += speed;
    }

    void Draw() {
        setfillcolor(color);
        fillcircle(x, y, radius);
        setlinecolor(BLACK);
        circle(x, y, radius);
    }

    bool IsOutOfScreen() {
        return y - radius > HEIGHT;
    }
};

int main() {
    initgraph(WIDTH, HEIGHT);
    BeginBatchDraw();

    srand((unsigned int)time(NULL));

    Player player(WIDTH / 2, HEIGHT - 100);
    std::vector<Enemy*> enemies;
    int score = 0;
    int counter = 0;

    while (true) {
        player.Input();

        counter++;
        if (counter >= 20) {
            counter = 0;
            int spawnX = rand() % (WIDTH - 100) + 50;
            enemies.push_back(new Enemy(spawnX, -20, 3, 20, GREEN));
        }

        for (int i = 0; i < (int)enemies.size(); i++) {
            enemies[i]->Update();
        }

        for (int i = 0; i < (int)enemies.size(); i++) {
            if (enemies[i]->IsOutOfScreen()) {
                delete enemies[i];
                enemies.erase(enemies.begin() + i);
                score++;
                i--;
            }
        }

        for (int i = 0; i < (int)enemies.size(); i++) {
            int dx = player.x - enemies[i]->x;
            int dy = player.y - enemies[i]->y;
            double dist = sqrt(dx * dx + dy * dy);
            if (dist < player.radius + enemies[i]->radius) {
                cleardevice();
                settextcolor(RED);
                settextstyle(50, 0, _T("System"));
                outtextxy(100, 300, _T("Game Over"));
                FlushBatchDraw();
                _getch();
                closegraph();
                return 0;
            }
        }

        cleardevice();

        char text[50];
        settextcolor(WHITE);
        settextstyle(20, 0, _T("System"));
        sprintf_s(text, sizeof(text), "Score: %d", score);
        outtextxy(10, 10, text);

        sprintf_s(text, sizeof(text), "Enemies: %d", (int)enemies.size());
        outtextxy(10, 40, text);

        player.Draw();
        for (int i = 0; i < (int)enemies.size(); i++) {
            enemies[i]->Draw();
        }

        FlushBatchDraw();
        Sleep(16);
    }

    for (int i = 0; i < (int)enemies.size(); i++) {
        delete enemies[i];
    }
    EndBatchDraw();
    closegraph();
    return 0;
}
